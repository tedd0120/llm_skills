# ============================================
# Teams 配置
# ============================================
TEAMS_EM_CODE=你的员工编码
TEAMS_AUTHORIZATION=你的授权令牌
TEAMS_GROUP_CODES=群组A,群组B,群组C

# ============================================
# Alpha Vantage API (财经新闻数据)
# ============================================
# ALPHAVANTAGE_API_KEY=your_api_key_here

# ============================================
# 小红书爬虫配置 (Xiaohongshu Scraper)
# ============================================
# Cookie 文件路径已固定为：
# .claude/skills/xiaohongshu-scraper/scripts/xhs_auth.json
# 无需再通过 .env 配置 XHS_AUTH_STATE

# 登录轮询间隔（秒），默认 2
# LOGIN_POLL_INTERVAL_SEC=2
